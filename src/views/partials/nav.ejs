<header class="topbar">
  <% const activeUser = typeof currentUser !== 'undefined' ? currentUser : null; %>
  <div>
    <a class="brand" href="/dashboard">SUMS 2.0</a>
    <p class="tagline">Smart University Academic and Placement Management System</p>
  </div>
  <% if (activeUser) { %>
    <nav class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <% if (activeUser.user_type === 'STUDENT') { %>
        <a href="/student/courses">Registration</a>
        <a href="/placements">Placements</a>
      <% } %>
      <% if (activeUser.user_type === 'FACULTY') { %>
        <a href="/faculty/attendance">Attendance</a>
        <a href="/faculty/grades">Grades</a>
      <% } %>
      <% if (activeUser.user_type === 'ADMIN') { %>
        <a href="/admin">Admin Console</a>
        <a href="/admin/students-directory">Students Directory</a>
        <a href="/admin/faculty-directory">Faculty Directory</a>
      <% } %>
      <form action="/logout" method="post" data-logout-form>
        <button class="ghost-button" type="submit">Sign Out</button>
      </form>
    </nav>
  <% } else { %>
    <nav class="nav-links">
      <a href="/login">Sign In</a>
    </nav>
  <% } %>
</header>
