<section class="page-head split-head">
  <div>
    <span class="eyebrow">Admin-only directory</span>
    <h1>Students Directory</h1>
    <p>Browse and filter all students across programs, departments, batches, and semesters.</p>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <h2>Student Filters</h2>
    <p>Showing <strong><%= students.length %></strong> records.</p>
  </div>
  <form class="stack-form inline-search" action="/admin/students-directory" method="get">
    <label>
      <span>Name</span>
      <input type="text" name="studentName" value="<%= studentFilters.studentName %>" placeholder="Student name" />
    </label>
    <label>
      <span>Roll Number</span>
      <input type="text" name="rollNumber" value="<%= studentFilters.rollNumber %>" placeholder="24BCS001" />
    </label>
    <label>
      <span>Email</span>
      <input type="text" name="studentEmail" value="<%= studentFilters.email %>" placeholder="@sums.edu" />
    </label>
    <label>
      <span>Phone</span>
      <input type="text" name="studentPhone" value="<%= studentFilters.phone %>" placeholder="9990000001" />
    </label>
    <label>
      <span>Gender</span>
      <select name="studentGender">
        <option value="">All genders</option>
        <% ['Male', 'Female', 'Non-Binary', 'Prefer Not To Say'].forEach((gender) => { %>
          <option value="<%= gender %>" <%= studentFilters.gender === gender ? 'selected' : '' %>><%= gender %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>DOB</span>
      <input type="date" name="studentDob" value="<%= studentFilters.dob %>" />
    </label>
    <label>
      <span>Admission Year</span>
      <select name="admissionYear">
        <option value="">All years</option>
        <% admissionYears.forEach((year) => { %>
          <option value="<%= year %>" <%= Number(studentFilters.admissionYear) === Number(year) ? 'selected' : '' %>><%= year %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Current Semester</span>
      <select name="currentSemester">
        <option value="">All semesters</option>
        <% semesters.forEach((semester) => { %>
          <option value="<%= semester %>" <%= Number(studentFilters.currentSemester) === Number(semester) ? 'selected' : '' %>><%= semester %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Department</span>
      <select name="departmentId">
        <option value="">All departments</option>
        <% departments.forEach((department) => { %>
          <option value="<%= department.department_id %>" <%= Number(studentFilters.departmentId) === Number(department.department_id) ? 'selected' : '' %>><%= department.department_name %></option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Program</span>
      <select name="programId">
        <option value="">All programs</option>
        <% programs.forEach((program) => { %>
          <option value="<%= program.program_id %>" <%= Number(studentFilters.programId) === Number(program.program_id) ? 'selected' : '' %>>
            <%= program.degree %> · <%= program.branch %>
          </option>
        <% }) %>
      </select>
    </label>
    <button class="primary-button" type="submit">Apply Student Filters</button>
    <a class="ghost-button" href="/admin/students-directory">Clear Filters</a>
  </form>
</section>

<section class="panel">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Roll Number</th>
          <th>Name</th>
          <th>Program</th>
          <th>Batch</th>
          <th>Semester</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Gender</th>
          <th>DOB</th>
        </tr>
      </thead>
      <tbody>
        <% if (students.length === 0) { %>
          <tr><td colspan="9">No students found for the selected filters.</td></tr>
        <% } %>
        <% students.forEach((student) => { %>
          <tr>
            <td><strong><%= student.roll_number %></strong></td>
            <td><%= student.name %></td>
            <td><%= student.degree %> · <%= student.branch %> · <%= student.department_name %></td>
            <td><%= student.admission_year %></td>
            <td><%= student.current_semester %></td>
            <td><%= student.email %></td>
            <td><%= student.phone %></td>
            <td><%= student.gender %></td>
            <td><%= new Date(student.dob).toISOString().slice(0, 10) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
