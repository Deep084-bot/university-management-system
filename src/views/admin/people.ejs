<section class="page-head split-head">
  <div>
    <span class="eyebrow">Admin-only directory</span>
    <h1>People Directory</h1>
    <p>Search and inspect students and faculty across the institute using role-specific filters.</p>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <h2>Students</h2>
    <p>Filter by roll number, name, program, semester, admission year, or email. Showing <strong><%= students.length %></strong> records.</p>
  </div>
  <form class="stack-form inline-search" action="/admin/people" method="get">
    <label>
      <span>Name</span>
      <input type="text" name="studentName" value="<%= studentFilters.studentName %>" placeholder="Search student name" />
    </label>
    <label>
      <span>Roll Number</span>
      <input type="text" name="rollNumber" value="<%= studentFilters.rollNumber %>" placeholder="24BCS001" />
    </label>
    <label>
      <span>Admission Year</span>
      <input type="number" name="admissionYear" min="2000" max="2100" value="<%= studentFilters.admissionYear || '' %>" />
    </label>
    <label>
      <span>Current Semester</span>
      <input type="number" name="currentSemester" min="1" max="12" value="<%= studentFilters.currentSemester || '' %>" />
    </label>
    <label>
      <span>Program</span>
      <select name="programId">
        <option value="">All programs</option>
        <% programs.forEach((program) => { %>
          <option value="<%= program.program_id %>" <%= String(studentFilters.programId || '') === String(program.program_id) ? 'selected' : '' %>>
            <%= program.degree %> · <%= program.branch %>
          </option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Email</span>
      <input type="text" name="studentEmail" value="<%= studentFilters.email %>" placeholder="@sums.edu" />
    </label>
    <button class="primary-button" type="submit">Search Students</button>
    <a class="ghost-button" href="/admin/people">Clear Filters</a>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Roll Number</th>
          <th>Name</th>
          <th>Program</th>
          <th>Batch</th>
          <th>Semester</th>
          <th>Email</th>
          <th>Phone</th>
        </tr>
      </thead>
      <tbody>
        <% if (students.length === 0) { %>
          <tr><td colspan="7">No students match the selected filters.</td></tr>
        <% } %>
        <% students.forEach((student) => { %>
          <tr>
            <td><strong><%= student.roll_number %></strong></td>
            <td>
              <strong><%= student.name %></strong><br />
              <span><%= student.gender %> · DOB <%= new Date(student.dob).toISOString().slice(0, 10) %></span>
            </td>
            <td><%= student.degree %> · <%= student.branch %></td>
            <td><%= student.admission_year %></td>
            <td><%= student.current_semester %></td>
            <td><%= student.email %></td>
            <td><%= student.phone %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <h2>Faculty</h2>
    <p>Filter by faculty name, employee code, designation, department, or email. Showing <strong><%= facultyMembers.length %></strong> records.</p>
  </div>
  <form class="stack-form inline-search" action="/admin/people" method="get">
    <label>
      <span>Name</span>
      <input type="text" name="facultyName" value="<%= facultyFilters.facultyName %>" placeholder="Search faculty name" />
    </label>
    <label>
      <span>Employee Code</span>
      <input type="text" name="employeeCode" value="<%= facultyFilters.employeeCode %>" placeholder="FAC-001" />
    </label>
    <label>
      <span>Designation</span>
      <input type="text" name="designation" value="<%= facultyFilters.designation %>" placeholder="Assistant Professor" />
    </label>
    <label>
      <span>Department</span>
      <select name="departmentId">
        <option value="">All departments</option>
        <% departments.forEach((department) => { %>
          <option value="<%= department.department_id %>" <%= String(facultyFilters.departmentId || '') === String(department.department_id) ? 'selected' : '' %>>
            <%= department.department_name %>
          </option>
        <% }) %>
      </select>
    </label>
    <label>
      <span>Email</span>
      <input type="text" name="facultyEmail" value="<%= facultyFilters.email %>" placeholder="@sums.edu" />
    </label>
    <button class="primary-button" type="submit">Search Faculty</button>
    <a class="ghost-button" href="/admin/people">Clear Filters</a>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Employee Code</th>
          <th>Name</th>
          <th>Designation</th>
          <th>Department</th>
          <th>Email</th>
          <th>Phone</th>
        </tr>
      </thead>
      <tbody>
        <% if (facultyMembers.length === 0) { %>
          <tr><td colspan="6">No faculty members match the selected filters.</td></tr>
        <% } %>
        <% facultyMembers.forEach((faculty) => { %>
          <tr>
            <td><strong><%= faculty.employee_code %></strong></td>
            <td>
              <strong><%= faculty.name %></strong><br />
              <span><%= faculty.gender %> · DOB <%= new Date(faculty.dob).toISOString().slice(0, 10) %></span>
            </td>
            <td><%= faculty.designation %></td>
            <td><%= faculty.department_name %></td>
            <td><%= faculty.email %></td>
            <td><%= faculty.phone %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
