<section class="hero hero-login">
  <div class="hero-copy">
    <span class="eyebrow">Security update required</span>
    <h1>Change your password to continue.</h1>
    <p>
      This is your first login with a system-generated password. Set a new password that only you know.
    </p>
  </div>

  <div class="panel auth-panel">
    <h2>Change Password</h2>
    <form class="stack-form" action="/change-password" method="post">
      <label>
        <span>New Password</span>
        <input type="password" name="newPassword" minlength="8" required />
      </label>
      <label>
        <span>Confirm Password</span>
        <input type="password" name="confirmPassword" minlength="8" required />
      </label>
      <button class="primary-button" type="submit">Update Password</button>
    </form>
  </div>
</section>
