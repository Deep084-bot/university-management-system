{
  "name": "smart-university-academic-placement-system",
  "version": "1.0.0",
  "description": "Smart University Academic and Placement Management System built with Node.js, Express.js, EJS, and PostgreSQL.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "setup": "node setup.js",
    "db:schema": "psql \"$DATABASE_URL\" -f sql/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f sql/seed.sql"
  },
  "keywords": [
    "postgresql",
    "express",
    "ejs",
    "mvc",
    "university-management"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.1",
    "morgan": "^1.10.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
